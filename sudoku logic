def is_valid(grid, r, c, n):
    for j in range(9):
        if grid[r][j] == n:
            return False
    for i in range(9):
        if grid[i][c] == n:
            return False
    br = (r // 3) * 3
    bc = (c // 3) * 3
    for i in range(br, br + 3):
        for j in range(bc, bc + 3):
            if grid[i][j] == n:
                return False
    return True
